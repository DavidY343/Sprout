# ===== Base de Datos =====
# Docker local: postgresql+asyncpg://postgres:password@db:5432/finance_db
# Supabase:     postgresql+asyncpg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:changeme_secure_password_123@db:5432/finance_db

# ===== PostgreSQL (solo para Docker Compose local) =====
POSTGRES_DB=finance_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_secure_password_123

# ===== JWT =====
SECRET_KEY=your_secret_key_here_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
# Separados por coma. En producción añadir tu dominio Vercel.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173